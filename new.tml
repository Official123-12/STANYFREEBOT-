  <!-- SERVICES SECTION (20+ Services) -->
  <section id="services" class="py-20 md:py-32 relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-brand-teal font-bold tracking-wide uppercase text-sm mb-3">What We Offer</h2>
        <h3 class="text-3xl md:text-5xl font-display font-bold text-white mb-4">Our Premium Services</h3>
        <p class="text-gray-400 max-w-2xl mx-auto">Comprehensive technology solutions tailored to accelerate your business growth and digital transformation.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <!-- Service 1 -->
        <div class="glass-panel p-6 rounded-2xl tech-card" data-aos="fade-up" data-aos-delay="100">
