          <a href="#portfolio" class="text-sm font-medium hover:text-white transition">Portfolio</a>
          <a href="#advice" class="text-sm font-medium hover:text-white transition">Advice</a>
          <a href="#help" class="text-sm font-medium hover:text-white transition">Help</a>
