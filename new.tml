  <!-- HERO SECTION -->
  <section id="home" class="relative z-10 min-h-screen flex items-center justify-center pt-20 md:pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col-reverse lg:flex-row items-center gap-12">
      <div class="lg:w-1/2 text-center lg:text-left" data-aos="fade-right">
