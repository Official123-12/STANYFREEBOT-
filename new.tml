        </div>

        <!-- Service 8 -->
        <div class="glass-panel p-6 rounded-2xl tech-card" data-aos="fade-up" data-aos-delay="800">
          <div class="w-14 h-14 rounded-xl bg-red-500/20 flex items-center justify-center text-red-400 text-2xl mb-4">
            <i class="fas fa-shield-alt"></i>
          </div>
          <h4 class="text-lg font-bold text-white mb-2">Cybersecurity</h4>
