        </div>

        <!-- Service 6 -->
        <div class="glass-panel p-6 rounded-2xl tech-card" data-aos="fade-up" data-aos-delay="600">
          <div class="w-14 h-14 rounded-xl bg-yellow-500/20 flex items-center justify-center text-yellow-400 text-2xl mb-4">
            <i class="fas fa-paint-brush"></i>
          </div>
          <h4 class="text-lg font-bold text-white mb-2">UI/UX Design</h4>
          <p class="text-gray-400 text-sm">Beautiful, intuitive interfaces that enhance user experience.</p>
        </div>

        <!-- Service 7 -->
        <div class="glass-panel p-6 rounded-2xl tech-card" data-aos="fade-up" data-aos-delay="700">
          <div class="w-14 h-14 rounded-xl bg-green-500/20 flex items-center justify-center text-green-400 text-2xl mb-4">
            <i class="fas fa-shopping-cart"></i>
          </div>
          <h4 class="text-lg font-bold text-white mb-2">E-Commerce</h4>
