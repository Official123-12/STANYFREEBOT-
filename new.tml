            <div class="text-3xl font-bold text-white" id="statProjects">0</div>
            <div class="text-xs text-gray-500 uppercase mt-1">Projects</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white" id="statClients">0</div>
            <div class="text-xs text-gray-500 uppercase mt-1">Clients</div>
