          <a href="#contact" class="px-5 py-2.5 rounded-full bg-gradient-to-r from-brand-purple to-brand-pink text-white text-sm font-semibold hover:shadow-lg hover:shadow-brand-purple/30 transition">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- MOBILE TOP BAR -->
  <div class="fixed top-0 left-0 right-0 z-40 glass-nav safe-top md:hidden">
    <div class="flex items-center justify-between h-14 px-4">
      <div class="flex items-center gap-2">
        <img src="https://raw.githubusercontent.com/Official123-12/STANYFREEBOT-/refs/heads/main/IMG_1378.jpeg" 
